<Window x:Class="REND.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rend" Height="520" Width="820" MinHeight="360" MinWidth="480" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header area (ASCII art) -->
        <TextBox Grid.Row="0"
                 Name="tbHeader"
                 IsReadOnly="True"
                 Background="Transparent"
                 BorderThickness="0"
                 FontFamily="Consolas"
                 FontSize="14"
                 Foreground="LightCyan"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Margin="0,0,0,8"/>

        <!-- Conversation area (fills remaining space, resizes with window) -->
        <TextBox Grid.Row="1"
                 Name="tbConversation"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 FontFamily="Consolas"
                 FontSize="14"
                 Background="Black"
                 Foreground="LightCyan"
                 Padding="12"
                 Margin="0"/>

        <!-- Input area: stretches horizontally with window -->
        <Border Grid.Row="2"
                Background="#FF0C0C0C"
                CornerRadius="6"
                Padding="8"
   >
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <!-- input expands/contracts -->
                    <ColumnDefinition Width="Auto" />
                    <!-- button stays fixed -->
                </Grid.ColumnDefinitions>

                <!-- Input TextBox: stretches with window width -->
                <TextBox Name="txtInput"
                         Grid.Column="0"
                         Height="36"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         FontFamily="Consolas"
                         Background="Black"
                         Foreground="LightCyan"
                         BorderThickness="0"
                         AcceptsReturn="False"
                         KeyDown="txtInput_KeyDown"
                         ToolTip="Type your message here and press Enter or click Send"
                         Padding="8,0"/>

                <!-- Send Button: fixed size -->
                <Button Name="btnSend"
                        Grid.Column="1"
                        Content="Send"
                        Width="92"
                        Height="36"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Click="btnSend_Click"
                        Background="#FF111111"
                        Foreground="LightCyan"
                        BorderBrush="#FF222222"
                        BorderThickness="1"/>
            </Grid>
        </Border>
    </Grid>
</Window>